#include <bang.h>
#include <torch/extension.h>
#include <vector>
#include "framework/core/MLUStream.h"

static torch::Tensor gru_cell(
    torch::Tensor x,
    torch::Tensor h,
    torch::Tensor w_ih,
    torch::Tensor w_hh,
    torch::Tensor b_ih,
    torch::Tensor b_hh) {
    int hidden_size = h.size(1);

    auto gi = x.mm(w_ih.t()).add(b_ih);
    auto gh = h.mm(w_hh.t()).add(b_hh);

    auto r_i = gi.narrow(1, 0, hidden_size);
    auto z_i = gi.narrow(1, hidden_size, hidden_size);
    auto n_i = gi.narrow(1, 2 * hidden_size, hidden_size);
    auto r_h = gh.narrow(1, 0, hidden_size);
    auto z_h = gh.narrow(1, hidden_size, hidden_size);
    auto n_h = gh.narrow(1, 2 * hidden_size, hidden_size);

    auto r = (r_i + r_h).sigmoid();
    auto z = (z_i + z_h).sigmoid();
    auto n = (n_i + r * n_h).tanh();

    return (1 - z) * n + z * h;
}

torch::Tensor bang_func(
    torch::Tensor x,
    int input_size,
    int hidden_size,
    int num_layers) {
    TORCH_CHECK(num_layers == 2, "GRU_forward basic task expects two layers");
    TORCH_CHECK(x.dim() == 3, "GRU_forward expects [batch, seq, input_size]");

    auto input = x.contiguous();
    auto options = input.options();
    int batch = input.size(0);
    int seq = input.size(1);

    auto w_ih_l0 = torch::randn({3 * hidden_size, input_size}, options);
    auto w_hh_l0 = torch::randn({3 * hidden_size, hidden_size}, options);
    auto b_ih_l0 = torch::randn({3 * hidden_size}, options);
    auto b_hh_l0 = torch::randn({3 * hidden_size}, options);
    auto w_ih_l1 = torch::randn({3 * hidden_size, hidden_size}, options);
    auto w_hh_l1 = torch::randn({3 * hidden_size, hidden_size}, options);
    auto b_ih_l1 = torch::randn({3 * hidden_size}, options);
    auto b_hh_l1 = torch::randn({3 * hidden_size}, options);

    auto h_l0 = torch::zeros({batch, hidden_size}, options);
    auto out_l0 = torch::zeros({batch, seq, hidden_size}, options);
    for (int t = 0; t < seq; t++) {
        h_l0 = gru_cell(input.select(1, t), h_l0, w_ih_l0, w_hh_l0, b_ih_l0, b_hh_l0);
        out_l0.select(1, t).copy_(h_l0);
    }

    auto h_l1 = torch::zeros({batch, hidden_size}, options);
    auto out_l1 = torch::zeros({batch, seq, hidden_size}, options);
    for (int t = 0; t < seq; t++) {
        h_l1 = gru_cell(out_l0.select(1, t), h_l1, w_ih_l1, w_hh_l1, b_ih_l1, b_hh_l1);
        out_l1.select(1, t).copy_(h_l1);
    }

    return out_l1;
}
